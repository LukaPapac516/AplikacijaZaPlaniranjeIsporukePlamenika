@model IEnumerable<PlameniciAplikacija.Models.Kupac>
@{
    ViewData["Title"] = "Kupci";
    var customers = Model?.ToList() ?? new List<PlameniciAplikacija.Models.Kupac>();
    var activeCustomers = customers.Count(k => k.Projekti != null && k.Projekti.Any());
    var noProjectCustomers = customers.Count(k => k.Projekti == null || !k.Projekti.Any());
}

<nav aria-label="Breadcrumb" class="app-breadcrumb">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Dashboard">Početna</a></li>
        <li class="breadcrumb-item active" aria-current="page">Kupci</li>
    </ol>
</nav>

<section class="lc-header">
    <div>
        <p class="lc-eyebrow">Baza partnera</p>
        <h2 class="lc-title">Kupci</h2>
        <p class="lc-subtitle">Pregled partnera, kontakata i povezanih projekata.</p>
    </div>
    <div class="lc-header-actions">
        <a asp-action="Create" class="btn btn-primary">Dodaj kupca</a>
    </div>
</section>

<section class="lc-kpi-row" aria-label="KPI kupaca">
    <article class="lc-kpi-chip"><span>Ukupno kupaca</span><strong>@customers.Count</strong></article>
    <article class="lc-kpi-chip"><span>Aktivni</span><strong>@activeCustomers</strong></article>
    <article class="lc-kpi-chip"><span>Bez projekata</span><strong>@noProjectCustomers</strong></article>
</section>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (customers.Any())
{
    <div class="lc-table-shell">
        <div class="lc-table-head">
            <h3>Pregled kupaca</h3>
            <span class="lc-table-meta">Redaka: @customers.Count</span>
        </div>
    <div class="table-responsive lc-table-wrap">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>Naziv</th>
                    <th>Grad</th>
                    <th>Kontakt osoba</th>
                    <th>Email</th>
                    <th>Telefon</th>
                    <th>Tip</th>
                    <th>Datum unosa</th>
                    <th>Aktivni projekti</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var kupac in customers)
                {
                    var detailId = $"customer-details-{kupac.Id}";
                    <tr>
                        <td class="fw-semibold">
                            <button class="btn btn-sm btn-link text-decoration-none p-0 me-2" type="button" data-bs-toggle="collapse" data-bs-target="#@detailId" aria-expanded="false" aria-controls="@detailId">
                                <span aria-hidden="true">▸</span>
                                <span class="visually-hidden">Prikaži detalje kupca @kupac.Naziv</span>
                            </button>
                            @kupac.Naziv
                        </td>
                        <td>@kupac.Grad</td>
                        <td>@kupac.KontaktOsoba</td>
                        <td>@kupac.Email</td>
                        <td>@kupac.Telefon</td>
                        <td>@kupac.Tip</td>
                        <td>@kupac.DatumUnosa.ToShortDateString()</td>
                        <td>@kupac.Projekti?.Count</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@kupac.Id" class="btn btn-sm btn-outline-secondary mb-1">Otvori</a>
                            <form asp-action="Delete" method="post" onsubmit="return confirm('Obrisati kupca i raskinuti vezu s projektima?');">
                                <input type="hidden" name="id" value="@kupac.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Obriši</button>
                            </form>
                        </td>
                    </tr>
                    <tr class="border-top-0">
                        <td colspan="9" class="pt-0 pb-0 border-top-0">
                            <div class="collapse" id="@detailId">
                                <div class="card card-body bg-light border-0 mb-2">
                                    <div class="row g-2 small">
                                        <div class="col-md-6"><strong>Naziv:</strong> @kupac.Naziv</div>
                                        <div class="col-md-6"><strong>Tip kupca:</strong> @kupac.Tip</div>
                                        <div class="col-md-6"><strong>Kontakt osoba:</strong> @kupac.KontaktOsoba</div>
                                        <div class="col-md-6"><strong>Email:</strong> @kupac.Email</div>
                                        <div class="col-md-6"><strong>Telefon:</strong> @kupac.Telefon</div>
                                        <div class="col-md-6"><strong>OIB:</strong> @kupac.OIB</div>
                                        <div class="col-12"><strong>Adresa:</strong> @kupac.Adresa, @kupac.Grad</div>
                                        <div class="col-md-6"><strong>Datum unosa:</strong> @kupac.DatumUnosa.ToShortDateString()</div>
                                        <div class="col-md-6"><strong>Broj projekata:</strong> @(kupac.Projekti?.Count ?? 0)</div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    </div>
}
else
{
    <p class="text-muted">Nema registriranih kupaca.</p>
}