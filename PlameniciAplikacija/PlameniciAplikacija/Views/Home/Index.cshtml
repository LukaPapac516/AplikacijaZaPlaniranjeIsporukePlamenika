@using PlameniciAplikacija.Models
@model IEnumerable<Project>
@{
    ViewData["Title"] = "Projekti";

    string GetStatusColor(string status)
    {
        return status switch
        {
            "NijeStartano" => "table-danger",
            "Startano" => "table-warning",
            "Zavrseno" => "table-success",
            "NijeUProizvodnji" => "table-secondary",
            "Gotovo" => "table-success",
            _ => string.Empty
        };
    }
}

<h2 class="mb-3">Projekti</h2>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">
        @successMessage
    </div>
    <script>
        alert('@successMessage');
    </script>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

<form method="get" asp-action="Index" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Pretraga: broj, naziv, kupac ili datum (npr. 4/10/2026)" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filtriraj</button>
    </div>
    <div class="col-md-2">
        <a asp-action="Create" class="btn btn-success w-100">Novi projekt</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Broj projekta</th>
                <th>Naziv projekta</th>
                <th>Kupac</th>
                <th>Datum unosa</th>
                <th>Status pripreme rada</th>
                <th>Status lansiranja</th>
                <th>Status proizvodnje</th>
                <th>Očekivani rok</th>
                <th>Realni rok</th>
                <th>Kašnjenje (dana)</th>
                <th>Napomena</th>
                <th>Prioritet</th>
                <th>Akcije</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var projekt in Model)
                {
                    var updateFormId = $"update-{projekt.Id}";
                    <tr>
                        <td>@projekt.BrojProjekta</td>
                        <td>@projekt.Naziv</td>
                        <td>@projekt.Kupac?.Naziv</td>
                        <td>@projekt.DatumUnosa.ToShortDateString()</td>
                        <td>
                            <select form="@updateFormId" name="statusPripremeRada" class="form-select form-select-sm @GetStatusColor(projekt.StatusPripremeRada.ToString())">
                                @foreach (var status in Enum.GetValues<StatusTriStanja>())
                                {
                                    if (status == projekt.StatusPripremeRada)
                                    {
                                        <option value="@status" selected>@status</option>
                                    }
                                    else
                                    {
                                        <option value="@status">@status</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select form="@updateFormId" name="statusLansiranja" class="form-select form-select-sm @GetStatusColor(projekt.StatusLansiranja.ToString())">
                                @foreach (var status in Enum.GetValues<StatusTriStanja>())
                                {
                                    if (status == projekt.StatusLansiranja)
                                    {
                                        <option value="@status" selected>@status</option>
                                    }
                                    else
                                    {
                                        <option value="@status">@status</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select form="@updateFormId" name="statusProizvodnje" class="form-select form-select-sm @GetStatusColor(projekt.StatusProizvodnje.ToString())">
                                @foreach (var status in Enum.GetValues<StatusProizvodnje>())
                                {
                                    if (status == projekt.StatusProizvodnje)
                                    {
                                        <option value="@status" selected>@status</option>
                                    }
                                    else
                                    {
                                        <option value="@status">@status</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>@projekt.OcekivaniRokIsporuke?.ToShortDateString()</td>
                        <td>
                            <input form="@updateFormId" type="date" name="realniRokIsporuke" value="@(projekt.RealniRokIsporuke?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
                        </td>
                        <td>@projekt.Kasnjenje</td>
                        <td>
                            <input form="@updateFormId" type="text" name="napomena" value="@projekt.Napomena" class="form-control form-control-sm" />
                        </td>
                        <td class="text-center">
                            <div class="form-check form-switch d-inline-flex align-items-center justify-content-center">
                                <input form="@updateFormId" class="form-check-input" type="checkbox" name="prioritet" value="true" @(projekt.Prioritet ? "checked" : string.Empty) />
                            </div>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@projekt.Id" class="btn btn-sm btn-secondary mb-1">Otvori</a>
                            <form id="@updateFormId" asp-action="Update" method="post" class="mb-1">
                                <input type="hidden" name="id" value="@projekt.Id" />
                                <button type="submit" class="btn btn-sm btn-primary">Spremi</button>
                            </form>
                            <form asp-action="Delete" method="post" class="mt-1" onsubmit="return confirm('Obrisati projekt?');">
                                <input type="hidden" name="id" value="@projekt.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="12" class="text-center">Nema projekata za prikaz.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
