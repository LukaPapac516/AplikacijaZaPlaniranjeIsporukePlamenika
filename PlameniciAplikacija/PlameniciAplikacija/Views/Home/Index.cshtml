@using PlameniciAplikacija.Models
@model IEnumerable<Project>
@{
    ViewData["Title"] = "Projekti";

    string GetStatusColor(string status)
    {
        return status switch
        {
            "NijeStartano" => "table-danger",
            "Startano" => "table-warning",
            "Zavrseno" => "table-success",
            "Gotovo" => "table-success",
            _ => string.Empty
        };
    }
}

<h2 class="mb-3">Projekti</h2>

<form method="get" asp-action="Index" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Pretraga po broju, nazivu, kupcu" />
    </div>
    <div class="col-md-2">
        <input type="date" name="dateFrom" value="@Context.Request.Query["dateFrom"]" class="form-control" />
    </div>
    <div class="col-md-2">
        <input type="date" name="dateTo" value="@Context.Request.Query["dateTo"]" class="form-control" />
    </div>
    <div class="col-md-2">
        <select name="statusPripreme" class="form-select" asp-items="Html.GetEnumSelectList<StatusTriStanja>()">
            <option value="">Priprema rada</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="statusLansiranja" class="form-select" asp-items="Html.GetEnumSelectList<StatusTriStanja>()">
            <option value="">Lansiranje</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="statusProizvodnje" class="form-select" asp-items="Html.GetEnumSelectList<StatusProizvodnje>()">
            <option value="">Proizvodnja</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filtriraj</button>
    </div>
    <div class="col-md-2">
        <a asp-action="Create" class="btn btn-success w-100">Novi projekt</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Broj projekta</th>
                <th>Naziv projekta</th>
                <th>Kupac</th>
                <th>Datum unosa</th>
                <th>Status pripreme rada</th>
                <th>Status lansiranja</th>
                <th>Status proizvodnje</th>
                <th>Očekivani rok</th>
                <th>Realni rok</th>
                <th>Kašnjenje (dana)</th>
                <th>Napomena</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var projekt in Model)
                {
                    <tr>
                        <td>@projekt.BrojProjekta</td>
                        <td>@projekt.Naziv</td>
                        <td>@projekt.Kupac?.Naziv</td>
                        <td>@projekt.DatumUnosa.ToShortDateString()</td>
                        <td class="@GetStatusColor(projekt.StatusPripremeRada.ToString())">@projekt.StatusPripremeRada</td>
                        <td class="@GetStatusColor(projekt.StatusLansiranja.ToString())">@projekt.StatusLansiranja</td>
                        <td class="@GetStatusColor(projekt.StatusProizvodnje.ToString())">@projekt.StatusProizvodnje</td>
                        <td>@projekt.OcekivaniRokIsporuke?.ToShortDateString()</td>
                        <td>@projekt.RealniRokIsporuke?.ToShortDateString()</td>
                        <td>@projekt.Kasnjenje</td>
                        <td>@projekt.Napomena</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="11" class="text-center">Nema projekata za prikaz.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
