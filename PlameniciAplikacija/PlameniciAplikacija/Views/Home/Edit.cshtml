@model PlameniciAplikacija.Models.Project
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Uredi projekt";
}

<h2>Uredi projekt</h2>
<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
    <div class="mb-3">
        <label asp-for="BrojProjekta" class="form-label"></label>
        <input asp-for="BrojProjekta" class="form-control" />
        <span asp-validation-for="BrojProjekta" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Naziv" class="form-label"></label>
        <input asp-for="Naziv" class="form-control" />
        <span asp-validation-for="Naziv" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="KupacId" class="form-label">Kupac</label>
        <select asp-for="KupacId" class="form-select" asp-items="@(new SelectList((IEnumerable<PlameniciAplikacija.Models.Kupac>)ViewBag.Kupci, "Id", "Naziv"))">
            <option value="">-- Odaberi kupca --</option>
        </select>
        <span asp-validation-for="KupacId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="DatumUnosa" class="form-label"></label>
        @{ ViewData["name"] = "DatumUnosa"; ViewData["value"] = Model?.DatumUnosa; ViewData["validationMessage"] = "Datum unosa je obavezan."; }
        @Html.Partial("_DateTimeControl")
        <span asp-validation-for="DatumUnosa" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="OcekivaniRokIsporuke" class="form-label"></label>
        @{ 
            ViewData["name"] = "OcekivaniRokIsporuke"; 
            ViewData["value"] = Model?.OcekivaniRokIsporuke; 
            ViewData["validationMessage"] = "Očekivani rok isporuke je obavezan";
        }
        @Html.Partial("_DateTimeControl")
        <span asp-validation-for="OcekivaniRokIsporuke" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="RealniRokIsporuke" class="form-label"></label>
        @{ ViewData["name"] = "RealniRokIsporuke"; ViewData["value"] = Model?.RealniRokIsporuke; }
        @Html.Partial("_DateTimeControl")
        <span asp-validation-for="RealniRokIsporuke" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Napomena" class="form-label"></label>
        <textarea asp-for="Napomena" class="form-control"></textarea>
        <span asp-validation-for="Napomena" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Vrsta plamenika</label>
        @{ 
            ViewData["name"] = "VrstaPlamenikaId"; 
            ViewData["value"] = Model?.VrstaPlamenika?.Naziv ?? string.Empty; 
            ViewData["placeholder"] = "Pretraži vrstu plamenika...";
            ViewData["apiUrl"] = Url.Action("Plamenici", "Lookup");
        }
        @Html.Partial("_AutocompleteDropdown")
    </div>

    <button type="submit" class="btn btn-primary">Spremi</button>
    <a asp-action="Index" class="btn btn-secondary">Odustani</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
