@using PlameniciAplikacija.Models
@model Project
@{
    ViewData["Title"] = $"Projekt {Model.BrojProjekta}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Projekt @Model.BrojProjekta - @Model.Naziv</h2>
    <a asp-action="Index" class="btn btn-link">&larr; Natrag na listu</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">
        @successMessage
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Kupac</dt>
                    <dd class="col-sm-7">@Model.Kupac?.Naziv</dd>
                    <dt class="col-sm-5">Datum unosa</dt>
                    <dd class="col-sm-7">@Model.DatumUnosa.ToShortDateString()</dd>
                    <dt class="col-sm-5">Očekivani rok</dt>
                    <dd class="col-sm-7">@Model.OcekivaniRokIsporuke?.ToShortDateString()</dd>
                    <dt class="col-sm-5">Realni rok</dt>
                    <dd class="col-sm-7">@Model.RealniRokIsporuke?.ToShortDateString()</dd>
                    <dt class="col-sm-5">Kašnjenje (dana)</dt>
                    <dd class="col-sm-7">@Model.Kasnjenje</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Status pripreme</dt>
                    <dd class="col-sm-7">@Model.StatusPripremeRada</dd>
                    <dt class="col-sm-5">Status lansiranja</dt>
                    <dd class="col-sm-7">@Model.StatusLansiranja</dd>
                    <dt class="col-sm-5">Status proizvodnje</dt>
                    <dd class="col-sm-7">@Model.StatusProizvodnje</dd>
                    <dt class="col-sm-5">Prioritet</dt>
                    <dd class="col-sm-7">@(Model.Prioritet ? "Da" : "Ne")</dd>
                    <dt class="col-sm-5">Napomena</dt>
                    <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(Model.Napomena) ? Model.Napomena : "-")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<h4>Radni nalozi</h4>
@if (Model.RadniNalozi != null && Model.RadniNalozi.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>Oznaka</th>
                    <th>Opis / Operacija</th>
                    <th>Datum otvaranja</th>
                    <th>Datum zatvaranja</th>
                    <th>Status</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var nalog in Model.RadniNalozi.OrderBy(n => n.DatumOtvaranja))
                {
                    var formId = $"nalog-{nalog.Id}";
                    <tr>
                        <td>@nalog.OznakaNaloga</td>
                        <td>
                            <input form="@formId" type="text" name="opis" value="@nalog.Opis" class="form-control form-control-sm" />
                        </td>
                        <td>
                            <input form="@formId" type="date" name="datumOtvaranja" value="@nalog.DatumOtvaranja.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                        </td>
                        <td>
                            <input form="@formId" type="date" name="datumZatvaranja" value="@(nalog.DatumZatvaranja?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
                        </td>
                        <td>
                            <select form="@formId" name="status" class="form-select form-select-sm">
                                @foreach (var status in Enum.GetValues<StatusNaloga>())
                                {
                                    if (status == nalog.Status)
                                    {
                                        <option value="@status" selected>@status</option>
                                    }
                                    else
                                    {
                                        <option value="@status">@status</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <form id="@formId" asp-action="UpdateRadniNalog" method="post" class="d-flex gap-2">
                                <input type="hidden" name="projektId" value="@Model.Id" />
                                <input type="hidden" name="nalogId" value="@nalog.Id" />
                                <button type="submit" class="btn btn-sm btn-primary">Spremi</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p class="text-muted">Ovaj projekt još nema radne naloge.</p>
}

@if (Model.StavkeProizvodnje != null && Model.StavkeProizvodnje.Any())
{
    <h4 class="mt-4">Stavke proizvodnje</h4>
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>Tip</th>
                    <th>Planiran datum</th>
                    <th>Datum završetka</th>
                    <th>Status</th>
                    <th>Napomena</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stavka in Model.StavkeProizvodnje)
                {
                    <tr>
                        <td>@stavka.Tip</td>
                        <td>@stavka.DatumPlaniranja?.ToShortDateString()</td>
                        <td>@stavka.DatumZavrsetka?.ToShortDateString()</td>
                        <td>@stavka.Status</td>
                        <td>@stavka.Napomena</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
